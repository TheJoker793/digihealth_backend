        {
          "Host": "${AUTH_HOST}",
          "Port": 5202
        }
      ],
      "DownstreamPathTemplate": "/api/v1/auth/logout",
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "QoSOptions": {
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 15000,
        "TimeoutValue": 5000
      }
    },

    {
